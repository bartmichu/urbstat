{
  "version": "0.18.2",
  "fmt": {
    "lineWidth": 200,
    "proseWrap": "preserve",
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "default-param-last",
        "eqeqeq",
        "guard-for-in",
        "no-await-in-loop",
        "no-console",
        "no-const-assign",
        "no-eval",
        "no-external-import",
        "no-non-null-asserted-optional-chain",
        "no-non-null-assertion",
        "no-self-compare",
        "no-sparse-arrays",
        "no-sync-fn-in-async-fn",
        "no-throw-literal",
        "no-undef",
        "no-useless-rename",
        "prefer-ascii",
        "single-var-declarator"
      ]
    }
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@1.0.0-rc.8",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.8",
    "@cliffy/table": "jsr:@cliffy/table@1.0.0-rc.8",
    "@std/cli": "jsr:@std/cli@^1.0.29",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "urbackup-server-api": "npm:urbackup-server-api@^0.92.4"
  },
  "minimumDependencyAge": "1440",
  "permissions": {
    "default": {
      "net": true,
      "read": ["./urbstat.conf"]
    }
  }
}
